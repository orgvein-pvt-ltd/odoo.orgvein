<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========== SECURITY GROUP ========== -->
    <record id="group_project_manager_custom" model="res.groups">
        <field name="name">Project Manager </field>
        <field name="category_id" ref="base.module_category_project"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user'))]"/>
    </record>


    <!-- ========== RECORD RULES ========== -->

    <!-- Rule: Project Manager can only SEE their own projects -->
    <record id="rule_project_manager_own_projects" model="ir.rule">
        <field name="name">Project Manager: See Own Projects Only</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="groups" eval="[(4, ref('group_project_manager_custom'))]"/>
        <field name="domain_force">
            [('user_id', '=', user.id)]
        </field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>  <!-- Cannot delete projects -->
    </record>

    <!-- Rule: Project Manager can only SEE tasks belonging to their own projects -->
    <record id="rule_project_manager_own_tasks" model="ir.rule">
        <field name="name">Project Manager: See Tasks in Own Projects Only</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="groups" eval="[(4, ref('group_project_manager_custom'))]"/>
        <field name="domain_force">
            [('project_id.user_id', '=', user.id)]
        </field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>  <!-- CAN delete tasks -->
    </record>

</odoo>